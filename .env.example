# Copy to .env and fill in. Application reads these via src/config/env.ts (no duplicate keys).

# Supabase (same URL/key used by frontend and by the Node API server)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional but recommended: local Node API (e.g. http://localhost:5000). Required for Programs, Fee Structures, Exchange Rates, etc.
VITE_API_URL=http://localhost:5000

# Backend only (Node server and db scripts) – do not use VITE_ prefix for secrets
DATABASE_URL=postgresql://user:password@host:5432/your_database
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_keiy
